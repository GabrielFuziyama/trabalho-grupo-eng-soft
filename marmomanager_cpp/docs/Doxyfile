PROJECT_NAME           = "MarmoManager"
PROJECT_NUMBER         = "1.1"
PROJECT_BRIEF          = "Sistema em C++/Qt para gerenciamento de ordens de serviço"

OUTPUT_DIRECTORY       = .
OUTPUT_LANGUAGE        = Portuguese

INPUT                  = ../includes ../src mainpage.dox
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.cpp *.dox
EXCLUDE_PATTERNS       = */build/* */docs/html/*

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
SEARCHENGINE           = YES
HTML_HEADER            = header.html

GENERATE_LATEX         = NO
HAVE_DOT               = YES
UML_LOOK               = YES
UML_LIMIT_NUM_FIELDS   = 50
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
MAX_DOT_GRAPH_DEPTH    = 0
